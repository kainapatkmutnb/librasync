<%- include('../partials/header') %>

<div class="page-header">
  <h1>รายงานการยืมปัจจุบัน</h1>
</div>

<div class="controls no-print report-controls">
  <div class="report-tabs">
    <a href="/reports/active-loans" class="btn btn-primary">การยืมปัจจุบัน</a>
    <a href="/reports/loan-history" class="btn btn-light">ประวัติทั้งหมด</a>
    <a href="/reports/member-borrow-summary" class="btn btn-light">สมาชิกยืมกี่ครั้ง</a>
  </div>

  <form class="report-filter-form" method="GET" action="/reports/active-loans">
    <div class="report-filter-field">
      <label for="active-from">วันที่ยืม (เริ่ม)</label>
      <input id="active-from" type="date" name="from" value="<%= filters && filters.from ? filters.from : '' %>" title="ตั้งแต่วันที่ยืม">
    </div>
    <div class="report-filter-field">
      <label for="active-to">วันที่ยืม (สิ้นสุด)</label>
      <input id="active-to" type="date" name="to" value="<%= filters && filters.to ? filters.to : '' %>" title="ถึงวันที่ยืม">
    </div>
    <div class="report-filter-field">
      <label for="active-member">สมาชิก</label>
      <select id="active-member" name="member_id">
        <option value="">สมาชิกทั้งหมด</option>
        <% (members || []).forEach(member => { %>
          <option value="<%= member.id %>" <%= String(filters && filters.member_id ? filters.member_id : '') === String(member.id) ? 'selected' : '' %>>
            <%= member.full_name %>
          </option>
        <% }) %>
      </select>
    </div>
    <div class="report-filter-actions">
      <button type="submit" class="btn btn-success">กรอง</button>
      <a href="/reports/active-loans" class="btn btn-neutral">ล้าง</a>
      <a href="/reports/active-loans?from=<%= encodeURIComponent(filters && filters.from ? filters.from : '') %>&to=<%= encodeURIComponent(filters && filters.to ? filters.to : '') %>&member_id=<%= encodeURIComponent(filters && filters.member_id ? filters.member_id : '') %>&format=csv" class="btn btn-excel"><i class="fas fa-file-excel"></i> ดาวน์โหลด Excel</a>
    </div>
  </form>
</div>

<!-- Print Header -->
<div class="print-header" style="display: none;">
  <h2>รายงานการยืมปัจจุบัน</h2>
  <p>วันที่พิมพ์: <%= printDate %></p>
  <p>จำนวนทั้งหมด: <%= activeLoans ? activeLoans.length : 0 %> รายการ</p>
</div>

<!-- Active Loans Table -->
<% if (activeLoans && activeLoans.length > 0) { %>
  <div class="table-center-shell">
  <table class="data-table">
    <thead>
      <tr>
        <th>ลำดับที่</th>
        <th>ชื่อหนังสือ</th>
        <th>ผู้แต่ง</th>
        <th>ผู้ยืม</th>
        <th>วันที่ยืม</th>
        <th>จำนวนวัน</th>
        <th class="no-print actions-column">จัดการ</th>
      </tr>
    </thead>
    <tbody>
      <% activeLoans.forEach((loan, index) => { %>
        <tr class="<%= loan.days_borrowed > 7 ? 'overdue' : '' %>">
          <td><%= index + 1 %></td>
          <td><%= loan.title %></td>
          <td><%= loan.author %></td>
          <td><%= loan.member %></td>
          <td><%= new Date(loan.borrow_date).toLocaleDateString('th-TH') %></td>
          <td>
            <span class="<%= loan.days_borrowed > 7 ? 'text-danger' : '' %>">
              <%= loan.days_borrowed %> วัน
              <% if (loan.days_borrowed > 7) { %>
                <span class="badge badge-danger">เกินกำหนด</span>
              <% } %>
            </span>
          </td>
          <td class="no-print actions-column">
            <form action="/loans/<%= loan.id %>/return" method="POST" onsubmit="return confirm('คืนหนังสือเล่มนี้?')">
              <button type="submit" class="btn btn-sm btn-success">↩️ คืนหนังสือ</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
  </div>
  
  <!-- Summary -->
  <div class="report-summary">
    <h3>สรุป</h3>
    <p>หนังสือที่กำลังถูกยืมทั้งหมด: <strong><%= activeLoans.length %></strong> เล่ม</p>
    <p>หนังสือที่เกินกำหนด 7 วัน: <strong class="text-danger"><%= activeLoans.filter(l => l.days_borrowed > 7).length %></strong> เล่ม</p>
  </div>
<% } else { %>
  <p class="no-data">ไม่มีหนังสือที่กำลังถูกยืม</p>
<% } %>

<%- include('../partials/footer') %>
