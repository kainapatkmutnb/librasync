<%- include('partials/header') %>

<div class="dashboard">
  <h1>แดชบอร์ด</h1>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-icon"><i class="fas fa-book"></i></div>
      <div class="stat-content">
        <h3>หนังสือทั้งหมด</h3>
        <p class="stat-number"><%= stats.totalBooks || 0 %></p>
      </div>
    </div>
    
    <div class="stat-card">
      <div class="stat-icon"><i class="fas fa-book-open"></i></div>
      <div class="stat-content">
        <h3>กำลังถูกยืม</h3>
        <p class="stat-number"><%= stats.activeLoans || 0 %></p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon"><i class="fas fa-check-circle"></i></div>
      <div class="stat-content">
        <h3>พร้อมให้ยืม</h3>
        <p class="stat-number"><%= stats.availableBooks || 0 %></p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon"><i class="fas fa-users"></i></div>
      <div class="stat-content">
        <h3>สมาชิกทั้งหมด</h3>
        <p class="stat-number"><%= stats.totalMembers || 0 %></p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon"><i class="fas fa-arrow-up"></i></div>
      <div class="stat-content">
        <h3>ยืมวันนี้</h3>
        <p class="stat-number"><%= stats.borrowedToday || 0 %></p>
      </div>
    </div>

    <div class="stat-card">
      <div class="stat-icon"><i class="fas fa-arrow-down"></i></div>
      <div class="stat-content">
        <h3>คืนวันนี้</h3>
        <p class="stat-number"><%= stats.returnedToday || 0 %></p>
      </div>
    </div>
  </div>

  <div class="dashboard-alerts">
    <div class="stat-card warning" title="เงื่อนไข: รายการที่ยังไม่คืนและยืมเกิน 7 วัน | query: <%= dashboardLinks && dashboardLinks.overdue ? dashboardLinks.overdue : '/reports/active-loans' %>">
      <div class="stat-icon"><i class="fas fa-exclamation-triangle"></i></div>
      <div class="stat-content">
        <h3>รายการเกินกำหนด 7 วัน</h3>
        <p class="stat-number"><%= stats.overdueLoans || 0 %></p>
        <a href="<%= dashboardLinks && dashboardLinks.overdue ? dashboardLinks.overdue : '/reports/active-loans' %>" class="text-link" title="query: <%= dashboardLinks && dashboardLinks.overdue ? dashboardLinks.overdue : '/reports/active-loans' %>">ดูรายการ</a>
      </div>
    </div>

    <div class="stat-card warning" title="เงื่อนไข: หนังสือที่เหลือให้ยืม <= 0 | query: <%= dashboardLinks && dashboardLinks.lowStock ? dashboardLinks.lowStock : '/books?availability=out-of-stock' %>">
      <div class="stat-icon"><i class="fas fa-layer-group"></i></div>
      <div class="stat-content">
        <h3>หนังสือใกล้หมดสต็อก</h3>
        <p class="stat-number"><%= stats.lowStockBooks || 0 %></p>
        <a href="<%= dashboardLinks && dashboardLinks.lowStock ? dashboardLinks.lowStock : '/books?availability=out-of-stock' %>" class="text-link" title="query: <%= dashboardLinks && dashboardLinks.lowStock ? dashboardLinks.lowStock : '/books?availability=out-of-stock' %>">จัดการหนังสือ</a>
      </div>
    </div>

    <% if (currentUser && currentUser.role === 'admin') { %>
      <div class="stat-card warning" title="เงื่อนไข: สมาชิกที่มียืมสะสมตั้งแต่ 3 ครั้งขึ้นไป | query: <%= dashboardLinks && dashboardLinks.highRisk ? dashboardLinks.highRisk : '/reports/member-borrow-summary?min_borrows=3' %>">
        <div class="stat-icon"><i class="fas fa-user-clock"></i></div>
        <div class="stat-content">
          <h3>สมาชิกค้างยืมหลายเล่ม</h3>
          <p class="stat-number"><%= stats.highRiskMembers || 0 %></p>
          <a href="<%= dashboardLinks && dashboardLinks.highRisk ? dashboardLinks.highRisk : '/reports/member-borrow-summary?min_borrows=3' %>" class="text-link" title="query: <%= dashboardLinks && dashboardLinks.highRisk ? dashboardLinks.highRisk : '/reports/member-borrow-summary?min_borrows=3' %>">ดูรายงานสมาชิก</a>
        </div>
      </div>
    <% } %>
  </div>

  <div class="dashboard-grid-two">
    <div class="dashboard-panel trend-panel">
      <h2>แนวโน้ม 7 วันล่าสุด (ยืม vs คืน)</h2>
      <% if (trends && trends.trend7 && trends.trend7.length > 0) { %>
        <div class="mini-chart">
          <% trends.trend7.forEach((item) => { %>
            <div class="mini-chart-row">
              <span class="mini-chart-label"><%= new Date(item.day).toLocaleDateString('th-TH') %></span>
              <div class="mini-chart-bars">
                <div class="mini-bar mini-bar-borrow" style="width:<%= (Number(item.borrow_count || 0) / (trends.maxTrend7 || 1)) * 100 %>%">
                  <span><%= item.borrow_count %></span>
                </div>
                <div class="mini-bar mini-bar-return" style="width:<%= (Number(item.return_count || 0) / (trends.maxTrend7 || 1)) * 100 %>%">
                  <span><%= item.return_count %></span>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="no-data">ยังไม่มีข้อมูลแนวโน้ม</p>
      <% } %>
    </div>

    <div class="dashboard-panel trend-panel">
      <h2>แนวโน้มตามช่วงเวลา (ยืม vs คืน)</h2>
      <div class="dashboard-switches no-print">
        <a href="<%= dashboardLinks && dashboardLinks.trend7 ? dashboardLinks.trend7 : '/?trend_days=7' %>" class="btn btn-light btn-sm <%= trends && Number(trends.trendDays) === 7 ? 'is-active' : '' %>">7 วัน</a>
        <a href="<%= dashboardLinks && dashboardLinks.trend30 ? dashboardLinks.trend30 : '/?trend_days=30' %>" class="btn btn-light btn-sm <%= trends && Number(trends.trendDays) === 30 ? 'is-active' : '' %>">30 วัน</a>
        <a href="<%= dashboardLinks && dashboardLinks.trend90 ? dashboardLinks.trend90 : '/?trend_days=90' %>" class="btn btn-light btn-sm <%= trends && Number(trends.trendDays) === 90 ? 'is-active' : '' %>">90 วัน</a>
      </div>
      <% if (trends && trends.trendSelected && trends.trendSelected.length > 0) { %>
        <div class="mini-chart compact">
          <% trends.trendSelected.forEach((item, index) => { %>
            <% if (Number(trends.trendDays || 30) === 7 || index % 3 === 0) { %>
              <div class="mini-chart-row">
                <span class="mini-chart-label"><%= new Date(item.day).toLocaleDateString('th-TH') %></span>
                <div class="mini-chart-bars">
                  <div class="mini-bar mini-bar-borrow" style="width:<%= (Number(item.borrow_count || 0) / (trends.maxTrendSelected || 1)) * 100 %>%">
                    <span><%= item.borrow_count %></span>
                  </div>
                  <div class="mini-bar mini-bar-return" style="width:<%= (Number(item.return_count || 0) / (trends.maxTrendSelected || 1)) * 100 %>%">
                    <span><%= item.return_count %></span>
                  </div>
                </div>
              </div>
            <% } %>
          <% }) %>
        </div>
      <% } else { %>
        <p class="no-data">ยังไม่มีข้อมูลแนวโน้ม</p>
      <% } %>
    </div>
  </div>

  <div class="dashboard-grid-two">
    <div class="dashboard-panel">
      <h2>Top 10 หนังสือที่ถูกยืมมากที่สุด</h2>
      <% if (topBooks && topBooks.length > 0) { %>
        <div class="table-center-shell">
        <table class="data-table dashboard-table">
          <thead>
            <tr>
              <th>อันดับ</th>
              <th>ชื่อหนังสือ</th>
              <th>ผู้แต่ง</th>
              <th>ยืมทั้งหมด</th>
              <th>กำลังยืม</th>
            </tr>
          </thead>
          <tbody>
            <% topBooks.forEach((book, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= book.title %></td>
                <td><%= book.author %></td>
                <td><%= book.total_borrows %></td>
                <td><%= book.active_borrows %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      <% } else { %>
        <p class="no-data">ยังไม่มีข้อมูลหนังสือ</p>
      <% } %>
    </div>

    <div class="dashboard-panel">
      <h2>Top 10 สมาชิกที่ยืมมากที่สุด</h2>
      <% if (topMembers && topMembers.length > 0) { %>
        <div class="table-center-shell">
        <table class="data-table dashboard-table">
          <thead>
            <tr>
              <th>อันดับ</th>
              <th>ชื่อสมาชิก</th>
              <th>ยืมทั้งหมด</th>
              <th>กำลังยืม</th>
              <th>ล่าสุดที่ยืม</th>
            </tr>
          </thead>
          <tbody>
            <% topMembers.forEach((member, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= member.full_name %></td>
                <td><%= member.total_borrows %></td>
                <td><%= member.active_borrows %></td>
                <td><%= member.last_borrow_date ? new Date(member.last_borrow_date).toLocaleDateString('th-TH') : '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      <% } else { %>
        <p class="no-data">ยังไม่มีข้อมูลสมาชิก</p>
      <% } %>
    </div>
  </div>

  <div class="dashboard-panel">
    <h2>ค้นหาสมาชิกแบบรวดเร็ว</h2>
    <form class="report-filter-form" method="GET" action="/">
      <div class="report-filter-field">
        <label for="dashboard-member-search">เลือกสมาชิก</label>
        <select id="dashboard-member-search" name="member_id">
          <option value="">ยังไม่เลือก</option>
          <% (memberOptions || []).forEach((member) => { %>
            <option value="<%= member.id %>" <%= String(selectedMemberId || '') === String(member.id) ? 'selected' : '' %>><%= member.full_name %> (<%= member.email %>)</option>
          <% }) %>
        </select>
      </div>
      <div class="report-filter-actions">
        <button type="submit" class="btn btn-success">ดูข้อมูล</button>
        <a href="/" class="btn btn-neutral">ล้าง</a>
      </div>
    </form>

    <% if (selectedMember) { %>
      <div class="report-summary dashboard-member-summary">
        <h3>สมาชิก: <%= selectedMember.full_name %> (<%= selectedMember.email %>)</h3>
        <p>จำนวนชื่อหนังสือที่เคยยืม: <strong><%= selectedMemberItems ? selectedMemberItems.length : 0 %></strong> เล่ม</p>
      </div>

      <% if (selectedMemberItems && selectedMemberItems.length > 0) { %>
        <div class="table-center-shell">
        <table class="data-table dashboard-table">
          <thead>
            <tr>
              <th>ลำดับที่</th>
              <th>ชื่อหนังสือ</th>
              <th>ผู้แต่ง</th>
              <th>ยืมทั้งหมด</th>
              <th>กำลังยืม</th>
              <th>วันที่ยืมล่าสุด</th>
              <th>วันที่คืนล่าสุด</th>
            </tr>
          </thead>
          <tbody>
            <% selectedMemberItems.forEach((item, index) => { %>
              <tr>
                <td><%= index + 1 %></td>
                <td><%= item.title %></td>
                <td><%= item.author %></td>
                <td><%= item.total_borrows %> ครั้ง</td>
                <td><%= item.active_borrows %> รายการ</td>
                <td><%= item.last_borrow_date ? new Date(item.last_borrow_date).toLocaleDateString('th-TH') : '-' %></td>
                <td><%= item.last_return_date ? new Date(item.last_return_date).toLocaleDateString('th-TH') : '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
        </div>
      <% } else { %>
        <p class="no-data">สมาชิกคนนี้ยังไม่มีประวัติยืม</p>
      <% } %>
    <% } %>
  </div>

  <div class="recent-activities">
    <h2>กิจกรรมล่าสุด 10 รายการ</h2>
    <% if (recentActivities && recentActivities.length > 0) { %>
      <div class="activity-list">
        <% recentActivities.forEach(activity => { %>
          <div class="activity-item">
            <div class="activity-icon">
              <%- activity.return_date ? '<i class="fas fa-undo"></i>' : '<i class="fas fa-paper-plane"></i>' %>
            </div>
            <div class="activity-content">
              <p>
                <strong><%= activity.Member ? activity.Member.full_name : 'ไม่ทราบชื่อ' %></strong>
                <%= activity.return_date ? 'คืน' : 'ยืม' %>
                <strong><%= activity.Book ? activity.Book.title : 'ไม่ทราบชื่อหนังสือ' %></strong>
              </p>
              <span class="activity-time"><%= new Date(activity.createdAt).toLocaleString('th-TH') %></span>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="no-data">ยังไม่มีกิจกรรม</p>
    <% } %>
  </div>

  <div class="quick-actions no-print">
    <h2>ทำงานด่วน</h2>
    <div class="action-buttons">
      <a href="/authors/new" class="btn btn-primary">➕ เพิ่มผู้แต่ง</a>
      <a href="/books/new" class="btn btn-primary">➕ เพิ่มหนังสือ</a>
      <a href="/members/new" class="btn btn-primary">➕ เพิ่มสมาชิก</a>
      <a href="/loans/new" class="btn btn-primary">📤 ยืมหนังสือ</a>
      <a href="/reports/active-loans" class="btn btn-secondary">📊 ดูรายงาน</a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
