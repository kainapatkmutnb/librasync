<%- include('../partials/header') %>

<div class="form-container">
  <h1><%= author ? 'แก้ไขผู้แต่ง' : 'เพิ่มผู้แต่ง' %></h1>
  
  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-error">
      <ul>
        <% errors.forEach(error => { %>
          <li><%= error.msg %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>
  
  <form method="POST" action="<%= author ? '/authors/' + author.id + '/update' : '/authors' %>">
    <div class="form-group">
      <label for="full_name">ชื่อ-นามสกุล <span class="required">*</span></label>
      <input 
        type="text" 
        id="full_name" 
        name="full_name" 
        value="<%= formData.full_name || (author ? author.full_name : '') %>"
        class="<%= errors && errors.find(e => e.path === 'full_name') ? 'error' : '' %>"
        required
      >
      <span id="duplicate_name_error" class="error-message" style="display: none;"></span>
      <% const nameError = errors && errors.find(e => e.path === 'full_name'); %>
      <% if (nameError) { %>
        <span class="error-message"><%= nameError.msg %></span>
      <% } %>
    </div>
    
    <div class="form-group">
      <label for="biography">ประวัติย่อ</label>
      <textarea 
        id="biography" 
        name="biography" 
        rows="5"
      ><%= formData.biography || (author ? author.biography : '') %></textarea>
    </div>
    
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">💾 บันทึก</button>
      <a href="/authors" class="btn btn-light">ยกเลิก</a>
    </div>
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const nameInput = document.getElementById('full_name');
    const duplicateError = document.getElementById('duplicate_name_error');
    const currentId = '<%= author ? author.id : "" %>';

    if (!nameInput || !duplicateError) {
      return;
    }

    let debounceTimer;

    const setDuplicateState = (message) => {
      if (message) {
        duplicateError.textContent = message;
        duplicateError.style.display = 'block';
        nameInput.setCustomValidity(message);
        return;
      }

      duplicateError.textContent = '';
      duplicateError.style.display = 'none';
      nameInput.setCustomValidity('');
    };

    const checkDuplicate = async () => {
      const value = (nameInput.value || '').trim();
      if (value.length < 2) {
        setDuplicateState('');
        return;
      }

      try {
        const query = new URLSearchParams({ value });
        if (currentId) {
          query.set('excludeId', currentId);
        }

        const response = await fetch(`/authors/check-duplicate?${query.toString()}`);
        const data = await response.json();
        setDuplicateState(data.duplicate ? 'ชื่อผู้แต่งนี้มีอยู่ในระบบแล้ว' : '');
      } catch (error) {
        setDuplicateState('');
      }
    };

    nameInput.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(checkDuplicate, 250);
    });

    nameInput.addEventListener('blur', checkDuplicate);
  });
</script>

<%- include('../partials/footer') %>
