<%- include('../partials/header') %>

<div class="form-container">
  <h1><%= member ? 'แก้ไขสมาชิก' : 'เพิ่มสมาชิก' %></h1>
  
  <% if (errors && errors.length > 0) { %>
    <div class="alert alert-error">
      <ul>
        <% errors.forEach(error => { %>
          <li><%= error.msg %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>
  
  <form method="POST" action="<%= member ? '/members/' + member.id + '/update' : '/members' %>">
    <div class="form-group">
      <label for="full_name">ชื่อ-นามสกุล <span class="required">*</span></label>
      <input 
        type="text" 
        id="full_name" 
        name="full_name" 
        value="<%= formData.full_name || (member ? member.full_name : '') %>"
        class="<%= errors && errors.find(e => e.path === 'full_name') ? 'error' : '' %>"
        required
      >
      <span id="duplicate_name_error" class="error-message" style="display: none;"></span>
      <% const nameError = errors && errors.find(e => e.path === 'full_name'); %>
      <% if (nameError) { %>
        <span class="error-message"><%= nameError.msg %></span>
      <% } %>
    </div>
    
    <div class="form-group">
      <label for="email">อีเมล <span class="required">*</span></label>
      <input 
        type="email" 
        id="email" 
        name="email" 
        value="<%= formData.email || (member ? member.email : '') %>"
        class="<%= errors && errors.find(e => e.path === 'email') ? 'error' : '' %>"
        required
      >
      <% const emailError = errors && errors.find(e => e.path === 'email'); %>
      <% if (emailError) { %>
        <span class="error-message"><%= emailError.msg %></span>
      <% } %>
    </div>
    
    <div class="form-group">
      <label for="phone_number">เบอร์โทรศัพท์ <span class="required">*</span></label>
      <input 
        type="tel" 
        id="phone_number" 
        name="phone_number" 
        value="<%= formData.phone_number || (member ? member.phone_number : '') %>"
        class="<%= errors && errors.find(e => e.path === 'phone_number') ? 'error' : '' %>"
        placeholder="เช่น 081-234-5678"
        inputmode="numeric"
        maxlength="14"
        required
      >
      <% const phoneError = errors && errors.find(e => e.path === 'phone_number'); %>
      <% if (phoneError) { %>
        <span class="error-message"><%= phoneError.msg %></span>
      <% } %>
    </div>
    
    <div class="form-group">
      <label for="joined_date">วันที่สมัคร <span class="required">*</span></label>
      <input 
        type="date" 
        id="joined_date" 
        name="joined_date" 
        value="<%= formData.joined_date || (member ? member.joined_date : new Date().toISOString().split('T')[0]) %>"
        class="<%= errors && errors.find(e => e.path === 'joined_date') ? 'error' : '' %>"
        required
      >
      <% const dateError = errors && errors.find(e => e.path === 'joined_date'); %>
      <% if (dateError) { %>
        <span class="error-message"><%= dateError.msg %></span>
      <% } %>
    </div>
    
    <div class="form-actions">
      <button type="submit" class="btn btn-primary">💾 บันทึก</button>
      <a href="/members" class="btn btn-light">ยกเลิก</a>
    </div>
  </form>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const nameInput = document.getElementById('full_name');
    const duplicateError = document.getElementById('duplicate_name_error');
    const currentId = '<%= member ? member.id : "" %>';
    const phoneInput = document.getElementById('phone_number');

    if (nameInput && duplicateError) {
      let debounceTimer;

      const setDuplicateState = (message) => {
        if (message) {
          duplicateError.textContent = message;
          duplicateError.style.display = 'block';
          nameInput.setCustomValidity(message);
          return;
        }

        duplicateError.textContent = '';
        duplicateError.style.display = 'none';
        nameInput.setCustomValidity('');
      };

      const checkDuplicate = async () => {
        const value = (nameInput.value || '').trim();
        if (value.length < 2) {
          setDuplicateState('');
          return;
        }

        try {
          const query = new URLSearchParams({ value });
          if (currentId) {
            query.set('excludeId', currentId);
          }

          const response = await fetch(`/members/check-duplicate?${query.toString()}`);
          const data = await response.json();
          setDuplicateState(data.duplicate ? 'ชื่อสมาชิกนี้มีอยู่ในระบบแล้ว' : '');
        } catch (error) {
          setDuplicateState('');
        }
      };

      nameInput.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(checkDuplicate, 250);
      });

      nameInput.addEventListener('blur', checkDuplicate);
    }

    if (!phoneInput) {
      return;
    }

    const formatPhone = (value) => {
      const digits = value.replace(/\D/g, '').slice(0, 10);

      if (digits.length <= 3) {
        return digits;
      }

      if (digits.length <= 6) {
        return `${digits.slice(0, 3)}-${digits.slice(3)}`;
      }

      return `${digits.slice(0, 3)}-${digits.slice(3, 6)}-${digits.slice(6)}`;
    };

    phoneInput.value = formatPhone(phoneInput.value || '');

    phoneInput.addEventListener('input', (event) => {
      event.target.value = formatPhone(event.target.value || '');
    });
  });
</script>

<%- include('../partials/footer') %>
